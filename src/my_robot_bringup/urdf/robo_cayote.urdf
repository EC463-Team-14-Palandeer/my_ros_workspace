<?xml version="1.0"?>
<robot name="robo_cayote" xmlns:xacro="http://ros.org/wiki/xacro">

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.26" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.45 0.31 0.06"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.45 0.31 0.06"/>
      </geometry>
    </collision>
  </link>

  <joint name="sliderjoint" type="prismatic">
    <parent link="base_link"/>
    <child link="solid"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.1" upper="0.1" effort="10" velocity="10"/>
    <origin xyz="0.31 -0.17 -0.165" rpy="0 0 0"/>
  </joint>
  <link name="solid"/>
  
  <joint name="steer_motor_fr" type="continuous">
    <parent link="solid"/>
    <child link="solid_0"/>
    <axis xyz="0 0 1"/>
    <limit effort="5" velocity="10"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="solid_0"/>
  
  <joint name="wheel_motor_fr" type="continuous">
    <parent link="solid_0"/>
    <child link="solid_1"/>
    <axis xyz="0 1 0"/>
    <limit effort="20" velocity="10"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="solid_1">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.095" length="0.08"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.095" length="0.08"/>
      </geometry>
    </collision>
  </link>
  <link name="appearance"/>
  <joint name="solid_1_appearance_joint" type="fixed">
    <parent link="solid_1"/>
    <child link="appearance"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="sliderjoint_2" type="prismatic">
    <parent link="base_link"/>
    <child link="solid_3"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.1" upper="0.1" effort="10" velocity="10"/>
    <origin xyz="0.31 0.17 -0.165" rpy="0 0 0"/>
  </joint>
  <link name="solid_3"/>
  
  <joint name="steer_motor_fl" type="continuous">
