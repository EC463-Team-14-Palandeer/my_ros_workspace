  </link>
  <link name="appearance_6"/>
  <joint name="solid_5_appearance_6_joint" type="fixed">
    <parent link="solid_5"/>
    <child link="appearance_6"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="sliderjoint_7" type="prismatic">
